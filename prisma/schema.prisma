// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL") // pooled
  directUrl = env("DIRECT_URL") // direct
}

/**
 * ---------- Enums ----------
 */
enum Role {
  USER
  HOST
  ADMIN
}

enum HostVerificationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum EventType {
  CONCERT
  FESTIVAL
}

enum PurchaseStatus {
  PENDING
  PAID
  CANCELED
  EXPIRED
}

model Venue {
  id          String   @id @default(cuid())
  placeId     String   @unique
  name        String
  address     String
  city        String
  country     String?
  countryCode String?  @db.VarChar(2)
  lat         Float?
  lng         Float?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  events Event[]
}

model Artist {
  id        String   @id @default(cuid())
  spotifyId String   @unique
  name      String
  image     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  events EventArtist[]
}

model EventArtist {
  eventId  String
  artistId String
  slot     DateTime // when they play
  order    Int? // optional ordering for billing line

  event  Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)
  artist Artist @relation(fields: [artistId], references: [id], onDelete: Cascade)

  @@id([eventId, artistId])
  @@index([artistId])
  @@index([slot])
}

/**
 * ---------- NextAuth core tables ----------
 */
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?

  birthdate DateTime? @db.Date

  countryCode        String?        @db.VarChar(2)
  country            String?
  city               String?
  followedSpotifyIds String[]       @default([])
  notifications      Notification[]

  role        Role         @default(USER)
  hostProfile HostProfile?

  credential            Credential?
  emailVerificationCode EmailVerificationCode?

  accounts Account[]

  tickets   Ticket[]
  events    Event[]    @relation("HostEvents")
  purchases Purchase[] // NEW

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Account {
  id                String @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String

  // token fields expected by NextAuth Prisma adapter
  refresh_token String?
  access_token  String?
  expires_at    Int?
  token_type    String?
  scope         String?
  id_token      String?
  session_state String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  // NOTE: do NOT mark userId as @unique; a user can have many accounts

  @@unique([provider, providerAccountId])
}

model EmailVerificationCode {
  id         String   @id @default(cuid())
  userId     String   @unique
  codeHash   String // SHA-256 of the 6-digit code
  createdAt  DateTime @default(now())
  expiresAt  DateTime
  attempts   Int      @default(0)
  lastSentAt DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([expiresAt])
}

/**
 * ---------- Local credentials (email/username + password) ----------
 */
model Credential {
  id           String   @id @default(cuid())
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

/**
 * ---------- Host profile ----------
 */
model HostProfile {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  displayName  String
  website      String?
  contactEmail String?
  phone        String?

  verification HostVerificationStatus @default(PENDING)
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt
}

/**
 * ---------- Domain models ----------
 */
model Event {
  id         String @id @default(cuid())
  title      String
  normalized String

  description String
  startAt     DateTime  @map("date")
  endAt       DateTime?

  eventType EventType
  posterUrl String?

  venueName   String
  city        String
  country     String?
  countryCode String? @db.VarChar(2)

  venueId String?
  venue   Venue?  @relation(fields: [venueId], references: [id])

  hostId String
  host   User   @relation("HostEvents", fields: [hostId], references: [id], onDelete: Cascade)

  tickets     Ticket[]
  ticketTiers TicketTier[]
  lineup      EventArtist[]
  purchases   Purchase[] // NEW

  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  Notification Notification[]

  @@unique([normalized, startAt, venueName, city])
}

model TicketTier {
  id          String @id @default(cuid())
  eventId     String
  category    String
  description String
  priceCents  Int
  currency    String @default("RON")
  quantity    Int

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  // NEW: opposite sides
  tickets       Ticket[] // ↔ Ticket.tier
  purchaseItems PurchaseItem[] // ↔ PurchaseItem.tier

  @@index([eventId])
}

model Ticket {
  id        String   @id @default(cuid())
  eventId   String
  ownerId   String?
  price     Int
  currency  String
  createdAt DateTime @default(now())

  // NEW (you already added these)
  tierId      String?
  purchaseId  String?
  code        String    @unique
  validatedAt DateTime?

  event    Event       @relation(fields: [eventId], references: [id], onDelete: Cascade)
  owner    User?       @relation(fields: [ownerId], references: [id], onDelete: SetNull)
  tier     TicketTier? @relation(fields: [tierId], references: [id], onDelete: SetNull)
  purchase Purchase?   @relation(fields: [purchaseId], references: [id], onDelete: SetNull)

  @@index([eventId])
  @@index([ownerId])
  @@index([tierId])
  @@index([purchaseId])
}

model Purchase {
  id              String         @id @default(cuid())
  userId          String
  eventId         String
  currency        String         @default("RON")
  totalCents      Int
  status          PurchaseStatus @default(PENDING)
  stripeSessionId String?        @unique
  stripePaymentId String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  user    User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  event   Event          @relation(fields: [eventId], references: [id], onDelete: Cascade)
  items   PurchaseItem[]
  tickets Ticket[]
}

model PurchaseItem {
  id             String @id @default(cuid())
  purchaseId     String
  tierId         String
  quantity       Int
  unitPriceCents Int

  purchase Purchase   @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  tier     TicketTier @relation(fields: [tierId], references: [id], onDelete: Restrict)

  @@index([purchaseId])
  @@index([tierId])
}

model Notification {
  id        String    @id @default(cuid())
  userId    String
  eventId   String? // ⬅️ link to the event
  message   String
  createdAt DateTime  @default(now())
  readAt    DateTime?

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  event Event? @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([eventId])
}
