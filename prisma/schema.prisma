// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL") // pooled
  directUrl = env("DIRECT_URL") // direct
}

/**
 * ---------- Enums ----------
 */
enum Role {
  USER
  HOST
  ADMIN
}

enum HostVerificationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum EventType {
  CONCERT
  FESTIVAL
}

model Venue {
  id          String   @id @default(cuid())
  placeId     String   @unique
  name        String
  address     String
  city        String
  country     String?
  countryCode String?  @db.VarChar(2)
  lat         Float?
  lng         Float?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  events Event[]
}

model Artist {
  id        String   @id @default(cuid())
  spotifyId String   @unique
  name      String
  genres    String[] // cache genres for fast render
  image     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  events EventArtist[]
}

model EventArtist {
  eventId  String
  artistId String
  slot     DateTime // when they play
  order    Int? // optional ordering for billing line

  event  Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)
  artist Artist @relation(fields: [artistId], references: [id], onDelete: Cascade)

  @@id([eventId, artistId])
  @@index([artistId])
  @@index([slot])
}

model TicketTier {
  id          String @id @default(cuid())
  eventId     String
  category    String
  description String
  priceCents  Int
  currency    String @default("RON")
  quantity    Int

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId])
}

/**
 * ---------- NextAuth core tables ----------
 */
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?

  // DATE only (no time zone drift)
  birthdate DateTime? @db.Date

  // NEW: location
  countryCode        String?        @db.VarChar(2) // ISO-3166 alpha-2, e.g., "RO"
  country            String? // "Romania"
  city               String? // "Cluj-Napoca"
  followedSpotifyIds String[]       @default([])
  notifications      Notification[] // back-reference for Notification.user

  role        Role         @default(USER)
  hostProfile HostProfile?

  credential            Credential?
  emailVerificationCode EmailVerificationCode?

  accounts Account[]
  sessions Session[]

  tickets Ticket[]
  events  Event[]  @relation("HostEvents")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Account {
  id                String @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String

  // token fields expected by NextAuth Prisma adapter
  refresh_token String?
  access_token  String?
  expires_at    Int?
  token_type    String?
  scope         String?
  id_token      String?
  session_state String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  // NOTE: do NOT mark userId as @unique; a user can have many accounts

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model EmailVerificationCode {
  id         String   @id @default(cuid())
  userId     String   @unique
  codeHash   String // SHA-256 of the 6-digit code
  createdAt  DateTime @default(now())
  expiresAt  DateTime
  attempts   Int      @default(0)
  lastSentAt DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([expiresAt])
}

/**
 * ---------- Local credentials (email/username + password) ----------
 */
model Credential {
  id           String   @id @default(cuid())
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

/**
 * ---------- Host profile ----------
 */
model HostProfile {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  displayName  String
  website      String?
  contactEmail String?
  phone        String?

  verification HostVerificationStatus @default(PENDING)
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt
}

/**
 * ---------- Domain models ----------
 */
model Event {
  id         String @id @default(cuid())
  title      String
  normalized String // lowercased/trimmed title for dedupe

  description String
  startAt     DateTime  @map("date") // reuse existing 'date' column name to avoid data migration
  endAt       DateTime?

  eventType EventType
  posterUrl String?

  venueName   String // snapshot string for easy querying
  city        String
  country     String?
  countryCode String? @db.VarChar(2)

  venueId String?
  venue   Venue?  @relation(fields: [venueId], references: [id])

  hostId String
  host   User   @relation("HostEvents", fields: [hostId], references: [id], onDelete: Cascade)

  // keep your existing relation
  tickets Ticket[]

  // new relations
  ticketTiers TicketTier[]
  lineup      EventArtist[]

  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  Notification Notification[]

  // update unique to use startAt + venue (or venueName fallback)
  @@unique([normalized, startAt, venueName, city])
}

model Ticket {
  id        String   @id @default(cuid())
  eventId   String
  ownerId   String? // ⬅️ make optional
  price     Int
  currency  String
  createdAt DateTime @default(now())

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  owner User? @relation(fields: [ownerId], references: [id], onDelete: SetNull) // ⬅️ SetNull
}

model Notification {
  id        String    @id @default(cuid())
  userId    String
  eventId   String? // ⬅️ link to the event
  message   String
  createdAt DateTime  @default(now())
  readAt    DateTime?

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  event Event? @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([eventId])
}
